using System.Collections.Generic;

// ReSharper disable All
namespace {{ NameSpace }}
{
    /// <summary>
    /// This class contains global option sets which are used in more than one entity!
    /// </summary>
    public sealed class OptionSetValues
    {
        private OptionSetValues() {}

{% for optionSet in OptionSets %}
        public struct {{ optionSet.Name | camelcase }}
        {
{% for option in optionSet.Options %}
            public const int {{ option.Label | sanitize | camelcase }} = {{ option.Value }};
{% endfor %}
        }
{% endfor %}
    }
}
