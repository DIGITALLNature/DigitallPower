<#@ template debug="false" hostspecific="false" language="C#" linePragmas="false" #>
/* eslint-disable */

declare namespace XrmEnum {
    // This module contains global option sets which are used in more than one entity!
    <# foreach(var optionSet in optionSets) { #>
    export const enum <#= CamelCase(optionSet.Key) #> {
    <# foreach(var option in optionSet.Value) { #>
        <#= Sanitize(CamelCase(option.Label)) #> = <#= option.Value #>,
    <# }#>
    }
    <#} #>
}
