/* eslint-disable */

declare namespace Xrm.Events {
    export interface EventContext {
        getFormContext<{{ SchemaName | camelcase }}FormContext>(): {{ SchemaName | camelcase }}FormContext;
    }
}

declare namespace XrmTable.{{ SchemaName | camelcase }} {
    export interface FormContext extends Xrm.FormContext {
        getAttribute():  Xrm.Attributes.Attribute<Xrm.Attributes.AttributeValues>[];
        getControl(): Xrm.Controls.Control[];
    {% for attr in Attributes  %}
        getAttribute(name: "{{ attr.LogicalName }}"): {{ attr.DefinitelyTypedAttributeType  }};
        getControl(name: "{{ attr.LogicalName }}"): {{ attr.DefinitelyTypedControlType  }};
    {% endfor -%}
    }

    export const EntityLogicalName = "{{ SchemaName }}";

    export const enum AttributeTypes {
    {%- for attr in Attributes  %}
        {{ attr.SchemaName | sanitize | camelcase | unique: "M"  }} =  "{{ attr.DefinitelyType }}",
    {%- endfor %}
    }

    export const enum Attributes {
    {%- for attr in Attributes  %}
        {{ attr.SchemaName | sanitize | camelcase | unique: "A"  }} =  "{{ attr.LogicalName }}",
    {%- endfor %}
    }
{% for pattr in PicklistAttributes  %}
    export const enum {{ pattr.SchemaName | sanitize | camelcase | unique: "O"  }}Code {
    {%- for option in pattr.Options  %}
        {{ option.Label | sanitize | camelcase   }} =  {{ option.Value }},
    {%- endfor %}
    }
{% endfor %}
}
