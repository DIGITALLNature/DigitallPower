{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "title": "EntityAllAssets",
    "description": "Configuration for entity assets with solution filtering",
    "properties": {
        "solution": {
            "type": "string",
            "description": "Solution name"
        },
        "strict": {
            "type": "boolean",
            "description": "Strict mode flag"
        },
        "whitelist": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Regex patterns for whitelisted items"
        },
        "blacklist": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Regex patterns for blacklisted items"
        }
    },
    "required": [
        "solution",
        "strict",
        "whitelist",
        "blacklist"
    ]
}