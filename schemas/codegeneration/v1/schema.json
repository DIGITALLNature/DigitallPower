{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "CodeGenerationConfig",
  "description": "Configuration for code generation",
  "properties": {
    "NameSpace": {
      "type": "string",
      "description": "Namespace for generated code",
      "default": "Digitall.APower.Model"
    },
    "Entities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Collection of entity names to include"
    },
    "Actions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of actions to include"
    },
    "CustomAPIs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of custom APIs to include"
    },
    "AdditionalSdkMessages": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Additional SDK messages to include"
    },
    "Solutions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of solutions to include"
    },
    "Forms": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of forms to include"
    },
    "EntityMask": {
      "type": [
        "string",
        "null"
      ],
      "description": "Entity mask pattern"
    },
    "SuppressDotNet": {
      "type": "boolean",
      "description": "Suppress .NET code generation",
      "default": false
    },
    "SuppressTypeScript": {
      "type": "boolean",
      "description": "Suppress TypeScript code generation",
      "default": false
    },
    "SuppressMetaData": {
      "type": "boolean",
      "description": "Suppress metadata generation",
      "default": false
    },
    "Hints": {
      "type": "boolean",
      "description": "Include hints in generated code",
      "default": true
    },
    "TypescriptGeneratorVersion": {
      "type": "string",
      "enum": [
        "Light",
        "Full"
      ],
      "description": "TypeScript generator version",
      "default": "Light"
    },
    "SuppressOptions": {
      "type": "boolean",
      "description": "Suppress options generation (DotNet & TypeScript)",
      "default": false
    },
    "SuppressLogicalNames": {
      "type": "boolean",
      "description": "Suppress logical names (DotNet only)",
      "default": false
    },
    "SuppressContext": {
      "type": "boolean",
      "description": "Suppress context generation (DotNet only)",
      "default": false
    },
    "SuppressActions": {
      "type": "boolean",
      "description": "Suppress actions generation (DotNet only)",
      "default": false
    },
    "SuppressSdkMessages": {
      "type": "boolean",
      "description": "Suppress SDK messages generation (DotNet & TypeScript)",
      "default": false
    },
    "SuppressRelations": {
      "type": "boolean",
      "description": "Suppress relations generation (DotNet only)",
      "default": false
    },
    "SuppressNavigationProperties": {
      "type": "boolean",
      "description": "Suppress navigation properties (DotNet only)",
      "default": false
    },
    "SuppressEntityTypeCode": {
      "type": "boolean",
      "description": "Suppress entity type code (DotNet only)",
      "default": false
    },
    "SuppressAlternateKeys": {
      "type": "boolean",
      "description": "Suppress alternate keys (DotNet only)",
      "default": false
    },
    "Virtual": {
      "type": "boolean",
      "description": "Make generated properties virtual (DotNet only)",
      "default": false
    },
    "UseBaseLanguage": {
      "type": "boolean",
      "description": "Use base language (DotNet only)",
      "default": false
    },
    "NonDebuggerNonUserCode": {
      "type": "boolean",
      "description": "Skip annotation of generated properties with 'DebuggerNonUserCode' (DotNet only)",
      "default": false
    },
    "EditableReadOnlyProperties": {
      "type": "boolean",
      "description": "Make generated readonly properties editable (DotNet only)",
      "default": false
    },
    "TypingPath": {
      "type": "string",
      "description": "Path to TypeScript typings (TypeScript only)",
      "default": "\"\"../../Typings/Xrm/index.d.ts\"\""
    },
    "OnlyFormsFromSolutions": {
      "type": "boolean",
      "description": "Only generate forms from solutions (TypeScript only)",
      "default": false
    },
    "EntityFilters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EntityFilter"
      },
      "description": "Entity filters (TypeScript only)"
    },
    "EntityRefFilters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EntityRefFilter"
      },
      "description": "Entity reference filters (TypeScript only)"
    },
    "EntityFormFilters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EntityFormFilter"
      },
      "description": "Entity form filters (TypeScript only)"
    },
    "SdkMessageFilters": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "SDK message filters (DotNet & TypeScript)"
    },
    "GlobalOptionSets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Global option sets (DotNet & TypeScript)"
    },
    "BusinessProcessFlows": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Business process flows (TypeScript only)"
    },
    "SuppressNullableSupport": {
      "type": "boolean",
      "description": "Suppress nullable support (DotNet only)",
      "default": false
    }
  },
  "$defs": {
    "EntityFilter": {
      "type": "object",
      "title": "EntityFilter",
      "description": "Filter configuration for entities",
      "properties": {
        "EntityName": {
          "type": "string",
          "description": "Name of the entity to filter"
        },
        "Attributes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Attributes to include/exclude"
        },
        "Include": {
          "type": "boolean",
          "description": "Whether this is an include or exclude filter",
          "default": true
        }
      },
      "required": [
        "EntityName"
      ],
      "additionalProperties": false
    },
    "EntityRefFilter": {
      "type": "object",
      "title": "EntityRefFilter",
      "description": "Filter configuration for entity references",
      "properties": {
        "EntityName": {
          "type": "string",
          "description": "Name of the entity to filter references for"
        },
        "References": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Reference attributes to include/exclude"
        },
        "Include": {
          "type": "boolean",
          "description": "Whether this is an include or exclude filter",
          "default": true
        }
      },
      "required": [
        "EntityName"
      ],
      "additionalProperties": false
    },
    "EntityFormFilter": {
      "type": "object",
      "title": "EntityFormFilter",
      "description": "Filter configuration for entity forms",
      "properties": {
        "EntityName": {
          "type": "string",
          "description": "Name of the entity to filter forms for"
        },
        "Forms": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Form names to include/exclude"
        },
        "Include": {
          "type": "boolean",
          "description": "Whether this is an include or exclude filter",
          "default": true
        }
      },
      "required": [
        "EntityName"
      ],
      "additionalProperties": false
    }
  }
}